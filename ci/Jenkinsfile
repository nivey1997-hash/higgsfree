// CI pipeline for higgsfree.
//
// Triggered by .github/workflows/wake-ec2.yml once a maintainer adds the
// "approved-for-ci" label: the Action wakes the GPU box and POSTs to
// /job/higgsfree/buildWithParameters with the PR number + head SHA.
//
// This job posts a GitHub *commit status* ("ci/pipeline-score") on the PR head
// SHA — that is the context required by branch protection on `main`, so the PR
// cannot be merged until the pipeline runs and the quality gate passes.

// Post a commit status to the PR head SHA (no-op for main/baseline builds).
def postStatus(String state, String desc) {
    if (!params.PR_SHA?.trim()) { return }
    sh """
        curl -s -X POST \
          -H "Authorization: token ${env.GITHUB_TOKEN}" \
          -H "Content-Type: application/json" \
          -d '{"state":"${state}","context":"ci/pipeline-score","description":"${desc}","target_url":"${env.BUILD_URL}"}' \
          "https://api.github.com/repos/kunal12203/higgsfree/statuses/${params.PR_SHA}" >/dev/null
    """
}

pipeline {
    agent any

    options {
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'PR_NUMBER', defaultValue: '', description: 'PR number (empty = main baseline build)')
        string(name: 'PR_SHA',    defaultValue: '', description: 'PR head commit SHA (used for the commit status)')
        string(name: 'PR_REF',    defaultValue: 'main', description: 'Branch to build when PR_NUMBER is empty')
    }

    environment {
        GITHUB_TOKEN = credentials('github-token')
        // Single source of truth for the CI test clip. Lives in a PRIVATE bucket
        // (avatar-graperoot-ci) that is NOT fronted by CloudFront, so it is not
        // publicly reachable — readable only via the worker instance role
        // (ci-sample-read inline policy). Fetched per run; never a manual file.
        SAMPLE_S3    = 's3://avatar-graperoot-ci/ci/sample.MOV'
        // PuLID + img2img run in their own venv (diffusers 0.25.0) so they don't
        // clash with Sonic's diffusers 0.29.0 in venv-sonic. avatar_gen defaults
        // this to venv-sonic, so it MUST be overridden here for CI.
        PULID_VENV_PYTHON = '/home/ubuntu/venv-pulid/bin/python'
        WORK_DIR     = "/home/ubuntu/ci_test/run_${env.BUILD_NUMBER}"
        TEST_VIDEO   = "/home/ubuntu/ci_test/run_${env.BUILD_NUMBER}/sample.MOV"
        OUTPUT_VIDEO = "/home/ubuntu/ci_test/run_${env.BUILD_NUMBER}/output.mp4"
        TEST_TEXT    = 'Hey! This is a quick test of the video generation pipeline.'
    }

    stages {

        stage('Pending status') {
            steps {
                script { postStatus('pending', 'Pipeline running on the GPU box') }
            }
        }

        stage('Checkout') {
            steps {
                script {
                    if (params.PR_NUMBER?.trim()) {
                        // Build the PR head commit exactly (what GitHub gates on).
                        checkout([$class: 'GitSCM',
                            branches: [[name: "${params.PR_SHA?.trim() ? params.PR_SHA : 'FETCH_HEAD'}"]],
                            userRemoteConfigs: [[
                                url: 'https://github.com/kunal12203/higgsfree.git',
                                refspec: "+refs/pull/${params.PR_NUMBER}/head:refs/remotes/origin/pr/${params.PR_NUMBER}"
                            ]]
                        ])
                    } else {
                        checkout([$class: 'GitSCM',
                            branches: [[name: "*/${params.PR_REF}"]],
                            userRemoteConfigs: [[url: 'https://github.com/kunal12203/higgsfree.git']]
                        ])
                    }
                }
            }
        }

        stage('Worker import smoke test') {
            // Gate: the backend worker must import cleanly (catches refactor drift
            // between core/steps and the worker's pipeline.* compat shim) BEFORE
            // any code can be merged or deployed.
            steps {
                sh '''
                    cd worker
                    PYTHONPATH="${WORKSPACE}" \
                    SQS_QUEUE_URL=dummy S3_BUCKET=dummy DATABASE_URL=postgresql://dummy AWS_REGION=us-east-1 \
                    /home/ubuntu/venv-sonic/bin/python -c "import worker; print('worker import OK')"
                '''
            }
        }

        stage('Get baseline score') {
            steps {
                script {
                    env.BASELINE = sh(
                        script: "cat /home/ubuntu/ci_test/baseline_score.txt 2>/dev/null || echo '0.0'",
                        returnStdout: true
                    ).trim()
                    echo "Baseline score: ${env.BASELINE}"
                }
            }
        }

        stage('Fetch test sample') {
            steps {
                sh """
                    mkdir -p ${env.WORK_DIR}
                    aws s3 cp ${env.SAMPLE_S3} ${env.TEST_VIDEO}
                    test -f ${env.TEST_VIDEO}
                """
            }
        }

        stage('Run pipeline') {
            steps {
                sh """
                    mkdir -p ${env.WORK_DIR}
                    /home/ubuntu/venv-sonic/bin/python pipelines/avatar_studio/run.py \
                        ${env.TEST_VIDEO} \
                        ${env.OUTPUT_VIDEO} \
                        ${env.WORK_DIR} \
                        --text '${env.TEST_TEXT}' \
                        --scene studio --aspect 9:16
                """
            }
        }

        stage('Score output') {
            steps {
                script {
                    env.SCORE = sh(
                        script: """
                            /home/ubuntu/venv-sonic/bin/python eval/score_pipeline.py \
                                ${env.TEST_VIDEO} \
                                ${env.OUTPUT_VIDEO} | tail -1
                        """,
                        returnStdout: true
                    ).trim()
                    echo "Pipeline score: ${env.SCORE}"
                }
            }
        }

        stage('Post PR comment') {
            when {
                expression { params.PR_NUMBER?.trim() }
            }
            steps {
                script {
                    def baseline = env.BASELINE.toFloat()
                    def score    = env.SCORE.toFloat()
                    def diff     = score - baseline
                    def arrow    = diff >= 0 ? "▲" : "▼"
                    def status   = diff >= 0 ? "✅" : "❌"
                    def diffStr  = String.format("%.3f", Math.abs(diff))
                    def scoreStr = String.format("%.3f", score)
                    def baseStr  = String.format("%.3f", baseline)

                    def body = """## ${status} Pipeline Quality Score

| Metric | Score |
|--------|-------|
| This PR | **${scoreStr}** |
| Baseline (main) | ${baseStr} |
| Diff | ${arrow} ${diffStr} |

**Score breakdown:** face identity similarity (50%) + lip sync confidence (50%)

_Tested on the L40S CI box · Build #${env.BUILD_NUMBER}_"""

                    sh """
                        curl -s -X POST \
                          -H "Authorization: token ${env.GITHUB_TOKEN}" \
                          -H "Content-Type: application/json" \
                          -d '{"body": ${groovy.json.JsonOutput.toJson(body)}}' \
                          "https://api.github.com/repos/kunal12203/higgsfree/issues/${params.PR_NUMBER}/comments" >/dev/null
                    """
                }
            }
        }

        stage('Quality gate') {
            when {
                expression { params.PR_NUMBER?.trim() }
            }
            steps {
                script {
                    def baseline = (env.BASELINE ?: '0.0').toFloat()
                    def score    = env.SCORE.toFloat()
                    // Allow a tiny epsilon so floating-point noise doesn't flap the gate.
                    if (score + 0.0005 < baseline) {
                        error("Quality regression: score ${score} < baseline ${baseline}")
                    }
                    echo "Quality gate passed: ${score} >= ${baseline}"
                }
            }
        }

        stage('Update baseline') {
            when {
                expression { !params.PR_NUMBER?.trim() }
            }
            steps {
                sh "echo ${env.SCORE} > /home/ubuntu/ci_test/baseline_score.txt"
                echo "Baseline updated to ${env.SCORE}"
            }
        }

        stage('Deploy to backend worker') {
            // CD: only on main (post-merge) builds, and only after the pipeline
            // ran + scored successfully above. Syncs this exact commit into the
            // worker's runtime dir and bounces the service.
            when {
                expression { !params.PR_NUMBER?.trim() }
            }
            steps {
                sh '''
                    DEST=/home/ubuntu/worker_app
                    mkdir -p "$DEST"
                    rsync -a --delete \
                      --exclude='.git/' --exclude='ci/' --exclude='.github/' \
                      --exclude='assets/' --exclude='docs/' --exclude='__pycache__/' \
                      "${WORKSPACE}/" "$DEST/"
                    # try-restart only bounces the worker if it is CURRENTLY running.
                    # The worker auto-stops the EC2 box when idle, so we must never
                    # start it here on an otherwise-idle CI box.
                    sudo systemctl try-restart avatar-worker.service
                    echo "Deployed $(git -C "${WORKSPACE}" rev-parse --short HEAD) to $DEST (try-restart issued)"
                '''
            }
        }
    }

    post {
        success { script { postStatus('success', "score ${env.SCORE}") } }
        failure { script { postStatus('failure', 'pipeline failed or quality regressed') } }
        always  { sh "rm -rf ${env.WORK_DIR} || true" }
    }
}
